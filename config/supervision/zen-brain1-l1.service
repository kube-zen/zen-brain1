[Unit]
Description=zen-brain1 L1 Worker (llama.cpp Qwen3.5-0.8B)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=neves
ExecStart=/home/neves/git/llama.cpp/build/bin/llama-server \
    -m /home/neves/git/ai/Qwen3.5-0.8B-Q4_K_M.gguf \
    --port 56227 --host 0.0.0.0 \
    --parallel 10 --ctx-size 65536 \
    --log-disable
Restart=always
RestartSec=5
StandardOutput=append:/var/log/zen-brain1/l1-worker.log
StandardError=append:/var/log/zen-brain1/l1-worker.log
PIDFile=/run/zen-brain1/l1-worker.pid

# Resource limits
MemoryMax=8G
CPUWeight=512

[Install]
WantedBy=multi-user.target
