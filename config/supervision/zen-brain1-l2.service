[Unit]
Description=zen-brain1 L2 Worker (llama.cpp Qwen3.5-2B)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=neves
ExecStart=/home/neves/git/llama.cpp/build/bin/llama-server \
    -m /home/neves/git/ai/zen-go-q4_k_m-latest.gguf \
    --port 60509 --host 0.0.0.0 \
    --ctx-size 16384 \
    --log-disable
Restart=always
RestartSec=5
StandardOutput=append:/var/log/zen-brain1/l2-worker.log
StandardError=append:/var/log/zen-brain1/l2-worker.log
PIDFile=/run/zen-brain1/l2-worker.pid

# Resource limits — 2B needs more memory
MemoryMax=12G
CPUWeight=256

[Install]
WantedBy=multi-user.target
