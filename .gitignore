# Binaries for programs and plugins
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Editor and IDE directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Kubernetes generated files
kustomization.yaml
kustomize/

# Local development configuration
config.dev.local.yaml
*.local

# Zen-Brain home directory (should not be committed)
# This is created at runtime based on ZEN_BRAIN_HOME
# The structure documentation is kept in README.md

# Temporary and cache directories
tmp/
.cache/
.env
.env.local
.env.*.local

# Log files
*.log
logs/

# Zen-Brain runtime directories
.zen/
zen-brain
