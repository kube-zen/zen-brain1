# Binaries for programs and plugins (root-only; cmd/apiserver and cmd/foreman source are tracked)
bin/
/apiserver
/foreman
/zen-brain
/controller
/create-jira-issues
/zen-brain1
*.exe
*.exe~
*.dll
*.so
*.dylib
demo_*
demo_qmd
demo_qmd.go

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool (canonical path: .artifacts/coverage/)
*.out
coverage.out
.artifacts/

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Editor and IDE directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Kubernetes generated files
kustomization.yaml
kustomize/

# Local development configuration
config.dev.local.yaml
*.local

# Zen-Brain home directory (should not be committed)
# This is created at runtime based on ZEN_BRAIN_HOME
# The structure documentation is kept in README.md

# Session persistence (SQLite)
data/

# Temporary and cache directories
tmp/
.cache/
.env
.env.local
.env.*.local

# Jira credentials (ZenLock bridge file for host runtime)
.zen-brain/jira-credentials.env

# Additional credential file patterns (ZB-013)
**/secrets/jira.yaml
**/.env.jira*
**/jira-input.yaml
**/jira-credentials.env
**/.zen-lock/*.key

# Log files
*.log
logs/

# Zen-Brain runtime directories (do not ignore cmd/zen-brain source)
.zen/
/zen-brain

# Temporary test binaries and scripts
test_zencontext*

# Scratch / one-off scripts and backups (do not commit)
*.backup
*.broken
*.clean
apply_template_*.py
fix_factory.py
remove_bounded.py
template_manager.patch

# Archive artifacts (do not commit)
*.tar.gz

# Python cache
__pycache__/
*.pyc

# Zen-Lock credentials (NEVER COMMIT)
DONOTASKMOREFORTHISSHIT.txt
ZENBRAIN*NEVERDELETETHISSHIT.age
zen-lock-private-key.age
zen-lock-public-key.age
