repositories:
  - name: kube-zen
    url: https://kube-zen.github.io/helm-charts

helmDefaults:
  createNamespace: false

environments:
  sandbox:
    kubeContext: k3d-zen-brain-sandbox
  staging:
    kubeContext: k3d-zen-brain-staging
  uat:
    kubeContext: k3d-zen-brain-uat

---
# Releases (order: zen-brain releases)
releases:
  - name: zen-brain-crds
    chart: ../../../charts/zen-brain-crds
    namespace: zen-brain
    force: false
    labels:
      component: crds

  - name: zen-lock
    labels:
      component: zen-lock
    namespace: zen-lock-system
    chart: kube-zen/zen-lock
    version: "0.0.3-alpha"
    timeout: 300
    atomic: true
    values:
      - ../../values/{{ .Environment.Name }}/zen-lock.yaml
    set:
      - name: image.repository
        value: {{ env "ZEN_LOCK_IMAGE_REPO" | default "zen-registry:5000/kubezen/zen-lock" }}
      - name: image.tag
        value: {{ env "ZEN_LOCK_TAG" | default "0.0.3-alpha" }}
      - name: privateKey.secretName
        value: zen-lock-master-key
      - name: privateKey.secretKey
        value: key.txt
      - name: controller.replicaCount
        value: 1
      - name: webhook.replicaCount
        value: 1

  - name: zen-brain-dependencies
    chart: ../../../charts/zen-brain-dependencies
    namespace: zen-context
    labels:
      component: dependencies
    values:
      - ../../../charts/zen-brain-dependencies/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-dependencies-values.yaml

  - name: zen-brain-ollama
    chart: ../../../charts/zen-brain-ollama
    namespace: zen-brain
    labels:
      component: ollama
    values:
      - ../../../charts/zen-brain-ollama/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-ollama-values.yaml

  - name: zen-brain-core
    chart: ../../../charts/zen-brain
    namespace: zen-brain
    labels:
      component: core
    values:
      - ../../../charts/zen-brain/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-values.yaml
