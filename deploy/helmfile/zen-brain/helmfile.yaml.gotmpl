repositories:
  - name: kube-zen
    url: https://kube-zen.github.io/helm-charts

helmDefaults:
  createNamespace: false

# H190B: KUBECONFIG ISOLATION — always use stack-scoped kubeconfig, never ~/.kube/config.
#   KUBECONFIG=.zen/state/kubeconfigs/zen-brain-<env>.yaml \
#     helmfile -f helmfile.yaml.gotmpl -e <env> apply
# See docs/runbooks/kubeconfig-isolation.md for full policy.

environments:
  sandbox:
    kubeContext: k3d-zen-brain-sandbox
    values:
      - stackIdentity:
          product: zen-brain
          stack: zen-brain
  staging:
    kubeContext: k3d-zen-brain-staging
    values:
      - stackIdentity:
          product: zen-brain
          stack: zen-brain
  uat:
    kubeContext: k3d-zen-brain-uat
    values:
      - stackIdentity:
          product: zen-brain
          stack: zen-brain

---
# Releases (order: zen-brain releases)
releases:
  - name: zen-brain-crds
    chart: ../../../charts/zen-brain-crds
    namespace: zen-brain
    force: false
    labels:
      component: crds

  - name: zen-lock
    labels:
      component: zen-lock
    namespace: zen-lock-system
    # Use local chart from helm-charts repo for sandbox hardening fixes
    chart: ../../../helm-charts/charts/zen-lock
    timeout: 300
    # Sandbox: atomic disabled temporarily for webhook cert job convergence
    # Will restore atomic:true after confirming webhook self-signed mode stable
    {{- if eq .Environment.Name "sandbox" }}
    atomic: false
    {{- else }}
    atomic: true
    {{- end }}
    values:
      - ../../values/{{ .Environment.Name }}/zen-lock.yaml
    set:
      - name: image.repository
        value: {{ env "ZEN_LOCK_IMAGE_REPO" | default "zen-registry:5000/kubezen/zen-lock" }}
      - name: image.tag
        value: {{ env "ZEN_LOCK_TAG" | default "f0570cf" }}
      - name: privateKey.secretName
        value: zen-lock-master-key
      - name: privateKey.secretKey
        value: key.txt
      - name: controller.replicaCount
        value: 1
      - name: webhook.replicaCount
        value: 1

  - name: zen-brain-dependencies
    chart: ../../../charts/zen-brain-dependencies
    namespace: zen-context
    labels:
      component: dependencies
    values:
      - ../../../charts/zen-brain-dependencies/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-dependencies-values.yaml

  # ⛔ DEPRECATED: zen-brain-ollama release is FORBIDDEN for zen-brain1.
  # Ollama is deprecated and forbidden. This release is commented out.
  # If you uncomment this, the CI ollama_forbidden_gate will fail.
  # - name: zen-brain-ollama
  #   chart: ../../../charts/deprecated/zen-brain-ollama
  #   namespace: zen-brain
  #   labels:
  #     component: ollama
  #   values:
  #     - ../../../charts/deprecated/zen-brain-ollama/values.yaml
  #     - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-ollama-values.yaml

  - name: zen-brain-core
    chart: ../../../charts/zen-brain
    namespace: zen-brain
    labels:
      component: core
    values:
      - ../../../charts/zen-brain/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-values.yaml
