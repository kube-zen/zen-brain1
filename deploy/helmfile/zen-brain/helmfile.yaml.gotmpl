# Zen-Brain Helmfile. Canonical deployment path.
# Run: helmfile -e <env> -f deploy/helmfile/zen-brain/helmfile.yaml.gotmpl sync
# Values: config/clusters.yaml → scripts/zen.py → .artifacts/state/<env>/*-values.yaml
# Do not use manual kubectl apply or kubectl exec ollama pull in the standard path.
#
# IMPORTANT: Ollama deployment model for Zen-Brain 1.0 dev/sandbox
# - The zen-brain-ollama release below is DISABLED by default in sandbox/dev
# - Default path: Host Docker Ollama (outside Kubernetes), accessed via host.k3d.internal:11434
# - In-cluster Ollama: Optional, legacy, experimental — not the default path
# - See config/clusters.yaml for sandbox use_ollama=false and host_ollama_base_url settings
---
helmDefaults:
  createNamespace: false
environments:
  sandbox:
  staging:
  uat:
---
# Order matters: crds → dependencies → ollama → core (needs omitted to avoid cross-namespace resolution).
releases:
  - name: zen-brain-crds
    chart: ../../../charts/zen-brain-crds
    namespace: zen-brain
    force: false
    labels:
      component: crds
    # CRDs only; no values

  - name: zen-brain-dependencies
    chart: ../../../charts/zen-brain-dependencies
    namespace: zen-context
    labels:
      component: dependencies
    values:
      - ../../../charts/zen-brain-dependencies/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-dependencies-values.yaml

  - name: zen-brain-ollama
    chart: ../../../charts/zen-brain-ollama
    namespace: zen-brain
    labels:
      component: ollama
    values:
      - ../../../charts/zen-brain-ollama/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-ollama-values.yaml

  - name: zen-brain-core
    chart: ../../../charts/zen-brain
    namespace: zen-brain
    labels:
      component: core
    values:
      - ../../../charts/zen-brain/values.yaml
      - ../../../.artifacts/state/{{ .Environment.Name }}/zen-brain-values.yaml
